# DeepSeek API Key（必填，LLM调用依赖它）
DEEPSEEK_API_KEY=

# Tavily 搜索 API Key（必填，News Analyst/Sector Analyst 依赖它做新闻搜索）
TAVILY_API_KEY=

# 共享访问密钥（可选）。留空 = 不启用鉴权（本地开发默认体验）。
# 部署到公网前建议设置，前端会要求访问者输入这个值才能调用分析接口。
ACCESS_KEY=

# 允许跨域访问的前端域名，逗号分隔（可选）。
# 默认只允许本地访问；部署后改成你的实际域名，例如：
# CORS_ORIGINS=https://your-domain.com,https://www.your-domain.com
CORS_ORIGINS=http://localhost:8000,http://127.0.0.1:8000
